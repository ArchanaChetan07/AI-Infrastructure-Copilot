# ════════════════════════════════════════════════════
# GPU Infrastructure Copilot — Environment Config
# Copy to .env and fill in your values
# ════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Mock / Fixture Mode (Day 1 default) ───────────
USE_MOCK_DATA=true
FIXTURES_DIR=fixtures

# ── LLM Settings ──────────────────────────────────
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Qdrant RAG (Day 2) ────────────────────────────
# Set QDRANT_ENABLED=true when running Qdrant (docker-compose up qdrant)
# When false, uses in-memory Qdrant automatically — no Docker needed
QDRANT_ENABLED=false
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=gpu_incident_logs
RAG_TOP_K=3

# ── PostgreSQL (Day 2) ────────────────────────────
# Set POSTGRES_ENABLED=true when running Postgres (docker-compose up postgres)
POSTGRES_ENABLED=false
POSTGRES_URL=postgresql+asyncpg://copilot:copilot@localhost:5432/gpu_copilot

# ── Slack Notifications (Day 2) ───────────────────
# 1. Create a Slack app: https://api.slack.com/apps
# 2. Add an Incoming Webhook
# 3. Paste the webhook URL below and set SLACK_ENABLED=true
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_CHANNEL=#gpu-alerts

# ── Prometheus Live Mode (future) ─────────────────
PROMETHEUS_ENABLED=false
PROMETHEUS_URL=http://localhost:9090

# ── Kubernetes Live Mode (future) ─────────────────
K8S_ENABLED=false
KUBECONFIG_PATH=~/.kube/config
